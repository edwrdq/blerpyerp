---
// src/pages/index.astro
const title = "Blerbyerp — The Open Language Lexicon";
const baseUrl = import.meta.env.BASE_URL;
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Syne:wght@700;800&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #0e0e0e;
      --surface: #141414;
      --surface2: #1a1a1a;
      --border: #1e1e1e;
      --border-hover: #2a2a2a;
      --text: #e8e6e1;
      --muted: #555;
      --dim: #333;
      --accent: #c8f060;
      --accent-dim: rgba(200,240,96,0.08);
      --mono: 'Share Tech Mono', monospace;
    }

    html { scroll-behavior: smooth; }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: var(--mono);
      min-height: 100vh;
    }

    .wrap {
      max-width: 860px;
      margin: 0 auto;
      padding: 0 24px;
    }

    /* NAV */
    nav {
      border-bottom: 1px solid var(--border);
      padding: 20px 0;
    }

    .nav-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 16px;
    }

    .logo {
      font-family: 'Syne', sans-serif;
      font-size: 1.1rem;
      font-weight: 800;
      letter-spacing: -0.02em;
      color: var(--text);
      text-decoration: none;
    }

    .logo span { color: var(--accent); }

    .nav-links {
      display: flex;
      gap: 24px;
      list-style: none;
    }

    .nav-links a {
      font-size: 11px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--muted);
      text-decoration: none;
      transition: color 0.15s;
    }

    .nav-links a:hover,
    .nav-links a[aria-current] { color: var(--accent); }

    /* HERO */
    .hero {
      padding: 56px 0 40px;
      border-bottom: 1px solid var(--border);
    }

    .hero-label {
      font-size: 11px;
      letter-spacing: 0.15em;
      color: var(--accent);
      margin-bottom: 14px;
    }

    h1 {
      font-family: 'Syne', sans-serif;
      font-size: clamp(2.4rem, 6vw, 3.8rem);
      font-weight: 800;
      line-height: 1;
      letter-spacing: -0.03em;
      color: var(--text);
      margin-bottom: 16px;
    }

    .hero-sub {
      font-size: 12px;
      color: var(--muted);
      line-height: 1.9;
      max-width: 440px;
    }

    .stats {
      display: flex;
      gap: 36px;
      margin-top: 28px;
      padding-top: 28px;
      border-top: 1px solid var(--border);
    }

    .stat-n {
      font-family: 'Syne', sans-serif;
      font-size: 1.6rem;
      font-weight: 700;
      color: var(--accent);
      display: block;
    }

    .stat-l {
      font-size: 10px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--dim);
      margin-top: 2px;
    }

    /* CONTROLS */
    .controls {
      padding: 28px 0 20px;
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    .search-row {
      position: relative;
    }

    #search {
      width: 100%;
      background: var(--surface);
      border: 1px solid var(--border-hover);
      border-radius: 4px;
      color: var(--text);
      font-family: var(--mono);
      font-size: 13px;
      padding: 12px 16px;
      outline: none;
      transition: border-color 0.15s;
    }

    #search:focus { border-color: var(--accent); }
    #search::placeholder { color: var(--muted); }

    .filters {
      display: flex;
      gap: 6px;
      flex-wrap: wrap;
    }

    .fbtn {
      background: var(--surface);
      border: 1px solid var(--border-hover);
      border-radius: 4px;
      color: var(--muted);
      font-family: var(--mono);
      font-size: 10px;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      padding: 7px 14px;
      cursor: pointer;
      transition: all 0.12s;
    }

    .fbtn:hover { color: var(--text); border-color: #3a3a3a; }

    .fbtn.active {
      background: var(--accent);
      border-color: var(--accent);
      color: #0e0e0e;
      font-weight: 700;
    }

    /* META */
    .meta {
      font-size: 10px;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--dim);
      padding-bottom: 16px;
      border-bottom: 1px solid var(--border);
      margin-bottom: 4px;
    }

    /* CARDS */
    #list {
      display: flex;
      flex-direction: column;
      gap: 2px;
      padding: 8px 0 32px;
    }

    .card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-left: 3px solid transparent;
      border-radius: 6px;
      padding: 20px 24px;
      cursor: pointer;
      transition: border-color 0.12s, background 0.12s;
    }

    .card:hover {
      border-color: var(--border-hover);
      border-left-color: var(--accent);
      background: var(--surface2);
    }

    .card.open {
      border-left-color: var(--accent);
      border-color: #2a2a2a;
      background: var(--surface2);
    }

    .card-top {
      display: flex;
      align-items: baseline;
      gap: 10px;
      flex-wrap: wrap;
    }

    .word {
      font-family: 'Syne', sans-serif;
      font-size: 1.25rem;
      font-weight: 700;
      letter-spacing: -0.01em;
      color: var(--text);
    }

    .pron {
      font-size: 11px;
      color: var(--muted);
      font-style: italic;
    }

    .badge {
      font-size: 9px;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      padding: 3px 8px;
      border-radius: 3px;
      margin-left: auto;
      flex-shrink: 0;
    }

    .noun        { background: rgba(96,212,240,0.1);  color: #60d4f0; }
    .verb        { background: rgba(240,96,168,0.1);  color: #f060a8; }
    .adjective   { background: rgba(200,240,96,0.1);  color: var(--accent); }
    .contraction { background: rgba(200,240,96,0.08); color: #a8cc40; }
    .other       { background: #1e1e1e; color: var(--muted); }

    .gloss {
      font-size: 12px;
      color: var(--accent);
      margin-top: 5px;
    }

    .gloss span { color: var(--muted); }

    /* EXPANDED */
    .card-body {
      display: none;
      margin-top: 16px;
      padding-top: 16px;
      border-top: 1px solid var(--border);
    }

    .card.open .card-body { display: block; }

    .def {
      font-size: 12px;
      line-height: 1.9;
      color: #aaa;
      margin-bottom: 14px;
    }

    .ex {
      background: var(--bg);
      border-left: 2px solid var(--accent);
      padding: 10px 14px;
      border-radius: 0 4px 4px 0;
      margin-bottom: 14px;
    }

    .ex-text {
      font-size: 12px;
      font-style: italic;
      color: var(--text);
      margin-bottom: 3px;
    }

    .ex-tr { font-size: 11px; color: var(--muted); }

    .morph-label {
      font-size: 10px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--dim);
      margin-bottom: 8px;
    }

    .chips {
      display: flex;
      gap: 6px;
      flex-wrap: wrap;
      margin-bottom: 14px;
    }

    .chip {
      background: var(--border);
      border: 1px solid var(--border-hover);
      border-radius: 3px;
      padding: 4px 10px;
      font-size: 11px;
      color: #aaa;
    }

    .chip b { color: var(--accent); }

    .tags { display: flex; gap: 5px; flex-wrap: wrap; }

    .tag {
      background: var(--accent-dim);
      color: #7a9830;
      font-size: 9px;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      padding: 3px 8px;
      border-radius: 3px;
    }

    /* EMPTY */
    .empty {
      text-align: center;
      padding: 48px 0;
      color: var(--muted);
      font-size: 12px;
    }

    /* FOOTER */
    footer {
      border-top: 1px solid var(--border);
      padding: 24px 0 40px;
    }

    .footer-inner {
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 8px;
    }

    .foot-text { font-size: 10px; color: var(--dim); letter-spacing: 0.08em; }

    .foot-link {
      font-size: 10px;
      color: var(--accent);
      text-decoration: none;
      letter-spacing: 0.08em;
    }

    .foot-link:hover { text-decoration: underline; }

    mark {
      background: rgba(200,240,96,0.18);
      color: var(--accent);
      border-radius: 2px;
    }

    @media (max-width: 600px) {
      .hero { padding: 36px 0 28px; }
      .stats { gap: 20px; }
      .card { padding: 16px 18px; }
      .nav-links { gap: 16px; }
    }
  </style>
</head>
<body>

<nav>
  <div class="wrap nav-inner">
    <a href="/" class="logo">blerb<span>yerp</span></a>
    <ul class="nav-links">
      <li><a href="/" aria-current="true">dictionary</a></li>
      <li><a href="/morphemes">morphemes</a></li>
      <li><a href="/idioms">idioms</a></li>
      <li><a href="/blog">blog</a></li>
      <li><a href="/changelog">changelog</a></li>
    </ul>
  </div>
</nav>

<main class="wrap" data-base={baseUrl}>
  <section class="hero">
    <p class="hero-label">// open source language</p>
    <h1>The Blerbyerp<br>Lexicon</h1>
    <p class="hero-sub">
      A constructed language built in public. Every word, morpheme, and idiom is versioned and open source — contribute on GitHub.
    </p>
    <div class="stats">
      <div><span class="stat-n" id="stat-words">—</span><span class="stat-l">words</span></div>
      <div><span class="stat-n" id="stat-morph">—</span><span class="stat-l">morphemes</span></div>
      <div><span class="stat-n" id="stat-idioms">—</span><span class="stat-l">idioms</span></div>
    </div>
  </section>

  <div class="controls">
    <div class="search-row">
      <input type="text" id="search" placeholder="search words, english, tags, definitions..." autocomplete="off" />
    </div>
    <div class="filters" id="filters">
      <button class="fbtn active" data-pos="all">all</button>
    </div>
  </div>

  <p class="meta" id="meta"></p>
  <div id="list"></div>
</main>

<footer>
  <div class="wrap footer-inner">
    <span class="foot-text">blerbyerp — public domain forever</span>
    <a href="https://github.com/YOURUSERNAME/blerbyerp" class="foot-link" target="_blank">contribute on github →</a>
  </div>
</footer>

<script>
  let allWords = [];
  let morphCount = 0;
  let idiomCount = 0;
  let activePos = 'all';
  let query = '';

  async function load() {
	const base = document.querySelector('main').dataset.base;
	const [dictRes, morphRes, idiomsRes] = await Promise.all([
  		fetch(`${base}data/dictionary.json`),
  		fetch(`${base}data/morphemes.json`),
  		fetch(`${base}data/idioms.json`),
	]);
    allWords = (await dictRes.json()).filter(w => !w._schema);
    const morphemes = await morphRes.json();
    const idioms = await idiomsRes.json();
    morphCount = morphemes.length;
    idiomCount = idioms.length;
    allWords.sort((a, b) => a.word.localeCompare(b.word));
    updateStats();
    buildFilters();
    render();
  }

  function updateStats() {
    document.getElementById('stat-words').textContent = allWords.length;
    document.getElementById('stat-morph').textContent = morphCount;
    document.getElementById('stat-idioms').textContent = idiomCount;
  }

  function buildFilters() {
    const poses = ['all', ...new Set(allWords.map(w => w.part_of_speech))];
    const container = document.getElementById('filters');
    container.innerHTML = poses.map(p =>
      `<button class="fbtn${p === 'all' ? ' active' : ''}" data-pos="${p}">${p === 'all' ? 'all' : p}</button>`
    ).join('');
    container.querySelectorAll('.fbtn').forEach(btn => {
      btn.addEventListener('click', () => {
        activePos = btn.dataset.pos;
        container.querySelectorAll('.fbtn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        render();
      });
    });
  }

  function posClass(pos) {
    return { noun: 'noun', verb: 'verb', adjective: 'adjective', adverb: 'adverb', contraction: 'contraction' }[pos] || 'other';
  }

  function hl(text, q) {
    if (!q) return text;
    const re = new RegExp(`(${q.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')})`, 'gi');
    return text.replace(re, '<mark>$1</mark>');
  }

  function render() {
    const q = query.trim().toLowerCase();
    const filtered = allWords.filter(w => {
      const matchPos = activePos === 'all' || w.part_of_speech === activePos;
      const matchQ = !q ||
        w.word.toLowerCase().includes(q) ||
        (w.english || '').toLowerCase().includes(q) ||
        (w.definition || '').toLowerCase().includes(q) ||
        (w.tags || []).some(t => t.toLowerCase().includes(q));
      return matchPos && matchQ;
    });

    document.getElementById('meta').textContent =
      `${filtered.length} word${filtered.length !== 1 ? 's' : ''}` +
      (activePos !== 'all' ? ` · ${activePos}` : '') +
      (q ? ` · "${q}"` : '');

    const list = document.getElementById('list');
    if (!filtered.length) {
      list.innerHTML = '<div class="empty">no words match.</div>';
      return;
    }

    list.innerHTML = filtered.map(w => {
      const morphEntries = Object.entries(w.morphemes || {});
      return `
        <div class="card" data-word="${w.word}">
          <div class="card-top">
            <span class="word">${hl(w.word, q)}</span>
            <span class="pron">${w.pronunciation || ''}</span>
            <span class="badge ${posClass(w.part_of_speech)}">${w.part_of_speech}</span>
          </div>
          <p class="gloss"><span>en → </span>${hl(w.english || '', q)}</p>
          <div class="card-body">
            <p class="def">${hl(w.definition || '', q)}</p>
            ${w.example ? `
              <div class="ex">
                <p class="ex-text">${w.example}</p>
                <p class="ex-tr">${w.example_translation || ''}</p>
              </div>` : ''}
            ${morphEntries.length ? `
              <p class="morph-label">// morphemes</p>
              <div class="chips">
                ${morphEntries.map(([k, v]) => `<span class="chip"><b>${k}</b> = ${v}</span>`).join('')}
              </div>` : ''}
            ${(w.tags || []).length ? `
              <div class="tags">
                ${w.tags.map(t => `<span class="tag">${t}</span>`).join('')}
              </div>` : ''}
          </div>
        </div>`;
    }).join('');

    list.querySelectorAll('.card').forEach(card => {
      card.addEventListener('click', () => card.classList.toggle('open'));
    });
  }

  document.getElementById('search').addEventListener('input', e => {
    query = e.target.value;
    render();
  });

  load().catch(console.error);
</script>

</body>
</html>	